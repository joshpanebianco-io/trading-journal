# Supabase connection for the client (safe to expose — protected by row-level security).
# Copy this file to client/.env.local and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# See SUPABASE_SETUP.md for the full walkthrough.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
