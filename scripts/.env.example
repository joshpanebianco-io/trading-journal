# Credentials for the one-time data migration (scripts/migrate-to-supabase.mjs).
# Copy this file to scripts/.env and fill in the values.
#
# WARNING: the service role key bypasses all row-level security. Keep it secret,
# never commit it, and never put it in the client. It's only used by this local script.
#   Supabase Dashboard → Project Settings → API → service_role key

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
MIGRATE_USER_EMAIL=you@example.com
